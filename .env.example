# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...your-anon-public-key...

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-change-this

# WhatsApp Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret-key-min-32-characters
WEBHOOK_VERIFY_TOKEN=verify-token-123

# Google Cloud Vision (Optional for OCR)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-cloud-service-account-key.json

# Server Configuration
PORT=3000
NODE_ENV=development

# Optional: Sentry for error tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
